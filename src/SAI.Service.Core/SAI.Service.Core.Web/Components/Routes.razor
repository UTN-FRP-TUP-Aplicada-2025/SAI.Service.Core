@*
    Enrutador del panel. Las superficies de trabajo exigen sesión ([Authorize]) vía
    AuthorizeRouteView; sin sesión, la guarda global (RedirigirAAcceso) redirige a
    /acceso o /alta-inicial según haya administrador. Las superficies de acceso
    declaran [AllowAnonymous] y su propio @@layout.
*@
<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
            <NotAuthorized>
                <RedirigirAAcceso />
            </NotAuthorized>
            <Authorizing>
                <MudProgressCircular Indeterminate="true" />
            </Authorizing>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MainLayout)">
            <h1 class="mud-typography mud-typography-h4">Página no encontrada</h1>
            <MudText>La superficie solicitada no existe.</MudText>
        </LayoutView>
    </NotFound>
</Router>
