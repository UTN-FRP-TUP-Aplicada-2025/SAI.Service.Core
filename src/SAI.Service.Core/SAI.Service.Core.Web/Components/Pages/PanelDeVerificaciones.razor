@page "/panel-de-verificaciones"
@attribute [Authorize]
@using SAI.Service.Core.Application.Equipos
@using SAI.Service.Core.Domain.Verificaciones
@using Microsoft.Extensions.DependencyInjection
@inject IServiceScopeFactory FabricaAlcances

<PageTitle>Panel de verificaciones — SAI.Service.Core</PageTitle>

<h1 class="mud-typography mud-typography-h4 mb-4">Panel de verificaciones</h1>

@if (_verificaciones is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_verificaciones.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Filled">
        Todavía no hay supuestos sembrados. <MudLink Href="/alta-de-equipos" Color="Color.Inherit"><b>Dá de alta un equipo</b></MudLink>.
    </MudAlert>
}
else
{
    var ahora = DateTimeOffset.UtcNow;
    var verificados = EvaluadorModalidad.Verificados(_verificaciones, ahora);
    var refutado = _verificaciones.Any(v => v.Estado == EstadoVerificacion.Refutado);
    var desbloqueado = verificados >= EvaluadorModalidad.SupuestosRequeridos;

    <MudAlert Severity="@(desbloqueado ? Severity.Success : Severity.Warning)" Variant="Variant.Filled" Class="mb-4" role="alert">
        <b>@verificados de @EvaluadorModalidad.SupuestosRequeridos</b> supuestos verificados.
        @if (desbloqueado)
        {
            <span> <b>Desbloqueado</b>: se habilita el apagado ordenado (la modalidad de acción se aplica cuando la política lo solicite).</span>
        }
        else if (refutado)
        {
            <span> Hay un supuesto <b>refutado</b> (bloqueo permanente): el servicio permanece en solo aviso hasta resolverlo.</span>
        }
        else
        {
            <span> El servicio permanece en <b>solo aviso</b> hasta verificar los cuatro.</span>
        }
    </MudAlert>

    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4" Icon="@Icons.Material.Filled.Warning">
        La ventana de mantenimiento incluye pruebas físicas (cortar la red, apagado con retorno), con presencia física.
        El apagado real por NUT está diferido; acá se ejercita el camino contra el adaptador configurado.
    </MudAlert>

    @if (_ocupado)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">Ejecutando la verificación…</MudText>
    }

    <MudGrid>
        @foreach (var v in _verificaciones.OrderBy(x => x.Supuesto))
        {
            var estado = v.EstadoEfectivo(ahora);
            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-4" Style="border-radius:10px;height:100%;">
                    <div class="d-flex align-center mb-1">
                        <MudIcon Icon="@IconoEstado(estado)" Color="@ColorEstado(estado)" Class="mr-2" />
                        <MudText Typo="Typo.subtitle1">@EtiquetaSupuesto(v.Supuesto)</MudText>
                        <MudSpacer />
                        <MudChip T="string" Size="Size.Small" Color="@ColorEstado(estado)" Variant="Variant.Text">@EtiquetaEstado(estado)</MudChip>
                    </div>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">@DescripcionSupuesto(v.Supuesto)</MudText>
                    @if (v.Evidencia is not null)
                    {
                        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2"><b>Evidencia:</b> @v.Evidencia</MudText>
                    }

                    @if (estado == EstadoVerificacion.Verificado)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Success" Class="d-block">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" Style="vertical-align:middle;" />
                            Verificado @(v.VigenciaHasta is { } h ? $"· vigente hasta {h.UtcDateTime:yyyy-MM-dd}" : "· sin caducidad")
                        </MudText>
                    }
                    else if (estado == EstadoVerificacion.NuncaVerificado || estado == EstadoVerificacion.Vencido)
                    {
                        @switch (v.Supuesto)
                        {
                            case Supuesto.PresupuestoDeApagado:
                                <div class="d-flex align-center" style="gap:0.5rem;">
                                    <MudNumericField T="int" @bind-Value="_segundos" Label="Segundos" Min="1" Style="max-width:120px;" Margin="Margin.Dense" Disabled="_ocupado" />
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_ocupado" OnClick="VerificarPresupuesto">Verificar</MudButton>
                                </div>
                                break;
                            case Supuesto.SenalEnBateria:
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_ocupado" OnClick="VerificarSenal">Verificar señal en batería</MudButton>
                                break;
                            case Supuesto.CorteConRetorno:
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_ocupado" OnClick="VerificarCorte">Verificar corte con retorno</MudButton>
                                break;
                            case Supuesto.ReencendidoPorPlaca:
                                <div class="d-flex align-center flex-wrap" style="gap:0.5rem;">
                                    <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="_ocupado" OnClick="() => Reencendido(true)">Arrancó solo</MudButton>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error" Disabled="_ocupado" OnClick="() => Reencendido(false)">No arrancó (refutar)</MudButton>
                                </div>
                                break;
                        }
                    }
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    @if (_mensaje is not null)
    {
        <MudAlert Severity="@_severidad" Variant="Variant.Filled" Class="mt-4">@_mensaje</MudAlert>
    }
}

@code {
    private IReadOnlyList<Verificacion>? _verificaciones;
    private int _segundos = 120;
    private bool _ocupado;
    private string? _mensaje;
    private Severity _severidad = Severity.Info;

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        using var alcance = FabricaAlcances.CreateScope();
        _verificaciones = await alcance.ServiceProvider.GetRequiredService<ServicioVerificacion>().EstadoAsync(CancellationToken.None);
    }

    private Task VerificarPresupuesto() => Ejecutar(s => s.VerificarPresupuestoAsync(_segundos, CancellationToken.None));
    private Task VerificarSenal() => Ejecutar(s => s.VerificarSenalBateriaAsync(CancellationToken.None));
    private Task VerificarCorte() => Ejecutar(s => s.VerificarCorteConRetornoAsync(CancellationToken.None));
    private Task Reencendido(bool arrancoSolo) => Ejecutar(s => s.RegistrarReencendidoAsync(arrancoSolo, CancellationToken.None));

    private async Task Ejecutar(Func<ServicioVerificacion, Task<ResultadoVerificacion>> accion)
    {
        _ocupado = true;
        try
        {
            using var alcance = FabricaAlcances.CreateScope();
            var resultado = await accion(alcance.ServiceProvider.GetRequiredService<ServicioVerificacion>());
            _mensaje = resultado.Mensaje;
            _severidad = resultado.Codigo switch
            {
                CodigoResultadoVerificacion.Verificado => Severity.Success,
                CodigoResultadoVerificacion.Refutado => Severity.Error,
                _ => Severity.Warning,
            };
        }
        finally
        {
            _ocupado = false;
            await Cargar();
        }
    }

    private static string EtiquetaSupuesto(Supuesto supuesto) => supuesto switch
    {
        Supuesto.PresupuestoDeApagado => "Tiempo de apagado del host",
        Supuesto.SenalEnBateria => "Señal en batería",
        Supuesto.ReencendidoPorPlaca => "Reencendido por placa",
        Supuesto.CorteConRetorno => "Corte con retorno",
        _ => supuesto.ToString(),
    };

    // Contexto breve de en qué consiste cada verificación (para el operador).
    private static string DescripcionSupuesto(Supuesto supuesto) => supuesto switch
    {
        Supuesto.PresupuestoDeApagado =>
            "Cronometrá a mano cuánto tarda el host en apagarse de forma ordenada bajo carga (con los contenedores detenidos) y confirmá que entra dentro del tiempo reservado. Vigencia 180 días.",
        Supuesto.SenalEnBateria =>
            "Cortá la energía de red y confirmá que el equipo reporta que pasó a batería (ups.status = OB): es la señal que dispara el apagado. Vigencia 365 días.",
        Supuesto.CorteConRetorno =>
            "Ejecutá un apagado con retorno y confirmá que el SAI corta la salida y la repone. Prueba el camino real de corte y reencendido del equipo. Sin caducidad.",
        Supuesto.ReencendidoPorPlaca =>
            "Al volver la energía, confirmá que el host arranca solo (autoencendido de la placa/BIOS). Si no arranca, se refuta: es un bloqueo permanente. Vigencia 365 días.",
        _ => string.Empty,
    };

    private static string EtiquetaEstado(EstadoVerificacion estado) => estado switch
    {
        EstadoVerificacion.NuncaVerificado => "Nunca verificado",
        EstadoVerificacion.Verificado => "Verificado",
        EstadoVerificacion.Vencido => "Vencido",
        EstadoVerificacion.Refutado => "Refutado (bloqueo permanente)",
        _ => estado.ToString(),
    };

    private static string IconoEstado(EstadoVerificacion estado) => estado switch
    {
        EstadoVerificacion.Verificado => Icons.Material.Filled.CheckCircle,
        EstadoVerificacion.Vencido => Icons.Material.Filled.Schedule,
        EstadoVerificacion.Refutado => Icons.Material.Filled.Block,
        _ => Icons.Material.Filled.HourglassEmpty,
    };

    private static Color ColorEstado(EstadoVerificacion estado) => estado switch
    {
        EstadoVerificacion.Verificado => Color.Success,
        EstadoVerificacion.Refutado => Color.Error,
        _ => Color.Warning,
    };
}
