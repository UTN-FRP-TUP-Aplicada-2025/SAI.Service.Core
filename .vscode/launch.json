{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Panel (SAI.Service.Core.Web)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/src/SAI.Service.Core/SAI.Service.Core.Web/bin/Debug/net10.0/SAI.Service.Core.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/SAI.Service.Core/SAI.Service.Core.Web",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      }
    }
  ]
}
